# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls
paper/*.toc
paper/*.texbak
paper/main.pdf
paper/figures_full_tmp/
# Pilot figures from early development (superseded by figures_full/)
paper/figures/

# Ruff / linting
.ruff_cache/

# Pytest
.pytest_cache/

# Environment
.env
*.env
.env.*

# Model weights (never commit)
*.bin
*.pt
*.pth
*.safetensors
*.gguf
*.ggml

# Large data files (use HuggingFace for distribution)
benchmark/rendered/
data/
results/*.jsonl
results/*_extracted.jsonl
results/*_v2.jsonl
results/pilot/
results/.archive/
results/human_eval/images/

# Explicitly include the per-model main evaluation results (critical reviewer
# evidence; ~6 MB each). Anything else under results/*.jsonl stays ignored.
!results/full_gpt4o.jsonl
!results/full_gemini.jsonl
!results/full_gemini25.jsonl
!results/full_qwen.jsonl
!results/full_qwen32b.jsonl
!results/full_claude.jsonl
!results/full_internvl.jsonl

# Run logs
logs/
*.log
nohup.out

# OMC / agent state (developer tooling, not part of release)
.omc/

# Notebooks output
notebooks/
*.ipynb_checkpoints/

# Obsolete arxiv staging area (uses old neurips_2025.sty)
release/arxiv/
release/structviz-bench-arxiv.zip

# HuggingFace local hf_dataset cache (regenerated on push)
release/huggingface/hf_dataset/
release/huggingface/human_eval_space/.git/
# Pre-rendered HF dataset images (kept on HF, not in code repo)
release/huggingface/benchmark/rendered/
# HF Space (Gradio app) — released separately to HF Spaces, not GitHub
release/huggingface/human_eval_space/
# HF benchmark JSONL copies — primary copy lives in benchmark/, HF release is generated
release/huggingface/benchmark/

# Ablation per-condition output files (regenerable via run_ablation.py viz-removal)
results/ablation/viz_removal_*.jsonl
results/ablation/prompt_*.jsonl
# Large mixed-eval per-model output (regenerable via run_mixed_eval.py)
results/mixed_*.jsonl
results/mixed_*.log

# Sensitive credentials
**/hf_token*
**/openai_key*
**/anthropic_key*
**/gemini_key*
**/api_key*
**/credentials*
*.pem
*.key
